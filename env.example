NODE_ENV=development
PORT=3010

# Single URI or host-based config (same pattern as notification-service)
# Local replica set (docker compose in this folder): see docker-compose.yml
# MONGODB_URI=mongodb://127.0.0.1:27017,127.0.0.1:27018,127.0.0.1:27019/voice_session_db?replicaSet=rs0&readPreference=secondaryPreferred
# If the driver cannot resolve members after connect, try host.docker.internal instead of 127.0.0.1 in the URI (Docker Desktop).

MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_NAME=voice_session_db

CORS_ORIGIN=*

# Swagger UI path (OpenAPI)
SWAGGER_PATH=api/docs

# Optional: disk health check path (default = drive root of cwd on Windows, / on Linux)
# HEALTH_DISK_PATH=C:\
