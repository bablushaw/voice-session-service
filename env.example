NODE_ENV=development
PORT=3010

# --- MongoDB (Docker replica set rs0 on host ports 27017/27018/27019) ---

# Prefer MONGODB_URI when set (it overrides MONGODB_HOST / MONGODB_PORT below).

#

# From your Mac: use directConnection (primary on 27017). Without this, the driver

# switches to replica hostnames mongo-rs0-* → ENOTFOUND mongo-rs0-1 unless /etc/hosts is set.

MONGODB_URI=mongodb://127.0.0.1:27017/voice_session_db?directConnection=true

#

# Full replica set URI only works from the host AFTER adding to /etc/hosts:

# if not able to edit try with sudo nano /etc/hosts

#   127.0.0.1 mongo-rs0-1 mongo-rs0-2 mongo-rs0-3

# Then uncomment:

#MONGODB_URI=mongodb://127.0.0.1:27017,127.0.0.1:27018,127.0.0.1:27019/voice_session_db?replicaSet=rs0

# With auth:

# MONGODB_URI=mongodb://USER:PASS@127.0.0.1:27017,127.0.0.1:27018,127.0.0.1:27019/voice_session_db?replicaSet=rs0&authSource=admin
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USER=
MONGODB_PASSWORD=
MONGODB_NAME=voice_session_db

# Optional overrides
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=5

CORS_ORIGIN=*

# Swagger UI path (OpenAPI)
SWAGGER_PATH=api/docs

# Optional: disk health check path (default = drive root of cwd on Windows, / on Linux)
# HEALTH_DISK_PATH=C:\